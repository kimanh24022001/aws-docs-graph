# AWS
AWS_PROFILE=aws-docs-graph
AWS_REGION=us-east-1

# Supabase (local dev — use Docker values; prod values in Parameter Store)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Neo4j (local dev — use Docker values; prod values in Parameter Store)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=devpassword
NEO4J_DATABASE=neo4j
AURA_INSTANCEID=
AURA_INSTANCENAME=

# Anthropic
ANTHROPIC_API_KEY=

# Java api-service (outbound call to Python)
PYTHON_SERVICE_URL=http://localhost:8001
PYTHON_SERVICE_FUNCTION_URL=  # prod only — Lambda Function URL

# Python agent-service (not used directly by Python; here for reference)
JAVA_SERVICE_URL=http://localhost:8080
